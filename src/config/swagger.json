{
  "openapi": "3.0.0",
  "info": {
    "title": "GigFlow API Documentation",
    "version": "1.0.0",
    "description": "Production-grade backend REST API for a freelance marketplace. Covers auth, user profiles, job feeds, bidding, escrow contracts, real-time messaging, and Paystack payments."
  },
  "servers": [
    {
      "url": "https://gigflow-452919660880.us-central1.run.app",
      "description": "Production Server"
    },
    {
      "url": "http://localhost:5000",
      "description": "Local Development Server"
    }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Enter your short-lived Access Token JWT."
      }
    },
    "schemas": {
      "RegisterInput": {
        "type": "object",
        "required": ["name", "email", "password"],
        "properties": {
          "name": { "type": "string", "example": "Charles Mark" },
          "email": { "type": "string", "format": "email", "example": "markcharleskojo@gmail.com" },
          "password": { "type": "string", "example": "Password123" },
          "role": { "type": "string", "enum": ["client", "freelancer"], "default": "freelancer" }
        }
      },
      "LoginInput": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": { "type": "string", "format": "email", "example": "markcharleskojo@gmail.com" },
          "password": { "type": "string", "example": "Password123" }
        }
      },
      "JobInput": {
        "type": "object",
        "required": ["title", "description", "category", "budget", "deadline"],
        "properties": {
          "title": { "type": "string", "example": "Build a REST API in Node.js" },
          "description": { "type": "string", "example": "Need an experienced developer to design and build an escrow payment API with express." },
          "category": { "type": "string", "example": "web_development" },
          "budget": { "type": "number", "example": 1500 },
          "deadline": { "type": "string", "format": "date-time", "example": "2026-06-10T12:00:00Z" },
          "tags": { "type": "array", "items": { "type": "string" }, "example": ["node", "express", "redis"] }
        }
      },
      "BidInput": {
        "type": "object",
        "required": ["amount", "proposal", "deliveryDays"],
        "properties": {
          "amount": { "type": "number", "example": 1200 },
          "proposal": { "type": "string", "example": "I have extensive experience with Node.js and Express. I can complete this on time." },
          "deliveryDays": { "type": "number", "example": 7 }
        }
      },
      "DepositInput": {
        "type": "object",
        "required": ["amount"],
        "properties": {
          "amount": { "type": "number", "example": 5000, "description": "Deposit amount in NGN/USD" }
        }
      },
      "MilestoneInput": {
        "type": "object",
        "required": ["title", "amount", "dueDate"],
        "properties": {
          "title": { "type": "string", "example": "Backend Architecture & Setup" },
          "amount": { "type": "number", "example": 500 },
          "dueDate": { "type": "string", "format": "date-time", "example": "2026-06-05T12:00:00Z" }
        }
      },
      "WithdrawalInput": {
        "type": "object",
        "required": ["amount", "accountNumber", "bankCode"],
        "properties": {
          "amount": { "type": "number", "example": 3000 },
          "accountNumber": { "type": "string", "example": "0123456789" },
          "bankCode": { "type": "string", "example": "058" }
        }
      }
    }
  },
  "paths": {
    "/health": {
      "get": {
        "summary": "System Health",
        "tags": ["Diagnostics"],
        "description": "Checks the operational status of database connection and redis instance.",
        "responses": {
          "200": { "description": "Healthy" },
          "503": { "description": "Degraded state (disconnected services)" }
        }
      }
    },
    "/metrics": {
      "get": {
        "summary": "Container Metrics",
        "tags": ["Diagnostics"],
        "description": "Returns memory usage and container uptime details.",
        "responses": {
          "200": { "description": "Metrics retrieved" }
        }
      }
    },
    "/api/auth/register": {
      "post": {
        "summary": "Register User",
        "tags": ["Auth"],
        "description": "Registers a new Client or Freelancer account.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/RegisterInput" } }
          }
        },
        "responses": {
          "201": { "description": "Successfully registered" }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "summary": "User Login",
        "tags": ["Auth"],
        "description": "Authenticate user credentials and receive JWT Access/Refresh tokens.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/LoginInput" } }
          }
        },
        "responses": {
          "200": { "description": "Login successful" },
          "403": { "description": "Email not verified or suspended" }
        }
      }
    },
    "/api/auth/verify-email": {
      "post": {
        "summary": "Verify Email",
        "tags": ["Auth"],
        "security": [{ "BearerAuth": [] }],
        "description": "Verify email via 6-digit OTP code.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["otp"],
                "properties": {
                  "otp": { "type": "string", "example": "123456" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Verified" }
        }
      }
    },
    "/api/auth/resend-otp": {
      "post": {
        "summary": "Resend OTP",
        "tags": ["Auth"],
        "security": [{ "BearerAuth": [] }],
        "description": "Resends verification code to the registered email.",
        "responses": {
          "200": { "description": "Resent" }
        }
      }
    },
    "/api/auth/refresh": {
      "post": {
        "summary": "Refresh Token",
        "tags": ["Auth"],
        "description": "Rotates refresh token and generates a new access token.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["refreshToken"],
                "properties": {
                  "refreshToken": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Rotated" }
        }
      }
    },
    "/api/auth/logout": {
      "post": {
        "summary": "User Logout",
        "tags": ["Auth"],
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["refreshToken"],
                "properties": {
                  "refreshToken": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Logged out" }
        }
      }
    },
    "/api/auth/kyc": {
      "post": {
        "summary": "Upload KYC Doc",
        "tags": ["Auth"],
        "security": [{ "BearerAuth": [] }],
        "description": "Upload a PDF/Image identification document to Cloudinary.",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["document"],
                "properties": {
                  "document": { "type": "string", "format": "binary" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Uploaded" }
        }
      }
    },
    "/api/users/me": {
      "get": {
        "summary": "Get Profile",
        "tags": ["Users"],
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": { "description": "Profile info" }
        }
      },
      "patch": {
        "summary": "Update Profile",
        "tags": ["Users"],
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string", "example": "Mark Charles" },
                  "skills": { "type": "array", "items": { "type": "string" }, "example": ["typescript", "docker"] },
                  "title": { "type": "string", "example": "Senior DevOps Engineer" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Updated" }
        }
      }
    },
    "/api/users/me/photo": {
      "patch": {
        "summary": "Upload Profile Photo",
        "tags": ["Users"],
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["photo"],
                "properties": {
                  "photo": { "type": "string", "format": "binary" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Photo updated" }
        }
      }
    },
    "/api/users/me/wallet": {
      "get": {
        "summary": "Get Wallet Info",
        "tags": ["Users"],
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": { "description": "Wallet balances & ledger transactions" }
        }
      }
    },
    "/api/users/me/portfolio": {
      "post": {
        "summary": "Add Portfolio Item",
        "tags": ["Users"],
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["title", "description"],
                "properties": {
                  "title": { "type": "string", "example": "Payment Escrow Library" },
                  "description": { "type": "string", "example": "Built a custom escrow logic." },
                  "link": { "type": "string", "example": "https://github.com/Charleskojomark" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Portfolio item added" }
        }
      }
    },
    "/api/users/me/portfolio/{itemId}": {
      "delete": {
        "summary": "Delete Portfolio Item",
        "tags": ["Users"],
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "itemId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Deleted" }
        }
      }
    },
    "/api/users/{id}": {
      "get": {
        "summary": "Get Public Profile",
        "tags": ["Users"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Public profile summary" }
        }
      }
    },
    "/api/jobs": {
      "get": {
        "summary": "Get Job Listings Feed",
        "tags": ["Jobs"],
        "parameters": [
          { "name": "q", "in": "query", "schema": { "type": "string" }, "description": "Search text matching tags or content" },
          { "name": "category", "in": "query", "schema": { "type": "string" } },
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 10 } }
        ],
        "responses": {
          "200": { "description": "Lists active jobs" }
        }
      },
      "post": {
        "summary": "Post Job Specs",
        "tags": ["Jobs"],
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/JobInput" } }
          }
        },
        "responses": {
          "201": { "description": "Job posting saved" }
        }
      }
    },
    "/api/jobs/{id}": {
      "get": {
        "summary": "Get Job Specification Details",
        "tags": ["Jobs"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Job details" }
        }
      },
      "put": {
        "summary": "Edit Job Specification Details",
        "tags": ["Jobs"],
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/JobInput" } }
          }
        },
        "responses": {
          "200": { "description": "Job updated" }
        }
      },
      "delete": {
        "summary": "Cancel Job Contract Specs",
        "tags": ["Jobs"],
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Job deleted" }
        }
      }
    },
    "/api/bids/mine": {
      "get": {
        "summary": "My Submitted Bids",
        "tags": ["Bids"],
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": { "description": "Bids array" }
        }
      }
    },
    "/api/bids/job/{jobId}": {
      "get": {
        "summary": "View Bids on Job",
        "tags": ["Bids"],
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "jobId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "List of bids for this job" }
        }
      },
      "post": {
        "summary": "Submit Bid Proposal",
        "tags": ["Bids"],
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "jobId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/BidInput" } }
          }
        },
        "responses": {
          "201": { "description": "Bid successfully placed" }
        }
      }
    },
    "/api/bids/{bidId}/accept": {
      "patch": {
        "summary": "Accept Bid & Create Contract",
        "tags": ["Bids"],
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "bidId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Bid accepted and contract generated" }
        }
      }
    },
    "/api/bids/{bidId}/withdraw": {
      "patch": {
        "summary": "Withdraw Proposal",
        "tags": ["Bids"],
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "bidId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Bid withdrawn" }
        }
      }
    },
    "/api/contracts": {
      "get": {
        "summary": "Get My Active Contracts",
        "tags": ["Contracts"],
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": { "description": "Contracts list" }
        }
      }
    },
    "/api/contracts/{id}": {
      "get": {
        "summary": "Contract Specifications Details",
        "tags": ["Contracts"],
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Contract details" }
        }
      }
    },
    "/api/contracts/{id}/milestones": {
      "post": {
        "summary": "Add Milestones to Contract",
        "tags": ["Contracts"],
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/MilestoneInput" }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Milestones added" }
        }
      }
    },
    "/api/contracts/{id}/milestones/{mId}/deliverable": {
      "post": {
        "summary": "Submit Deliverables",
        "tags": ["Contracts"],
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "mId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["contentUrl"],
                "properties": {
                  "contentUrl": { "type": "string", "example": "https://github.com/deliverable" },
                  "notes": { "type": "string", "example": "Finished components." }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Deliverable updated" }
        }
      }
    },
    "/api/contracts/{id}/milestones/{mId}/approve": {
      "patch": {
        "summary": "Approve Milestone & Release Escrow",
        "tags": ["Contracts"],
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "mId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Milestone approved and payouts released" }
        }
      }
    },
    "/api/contracts/{id}/dispute": {
      "post": {
        "summary": "Raise Contract Dispute",
        "tags": ["Contracts"],
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["reason"],
                "properties": {
                  "reason": { "type": "string", "example": "Seller went offline." }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Dispute opened" }
        }
      }
    },
    "/api/contracts/{id}/review": {
      "post": {
        "summary": "Write Contract Review",
        "tags": ["Contracts"],
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["rating", "comment"],
                "properties": {
                  "rating": { "type": "number", "minimum": 1, "maximum": 5, "example": 5 },
                  "comment": { "type": "string", "example": "Work completed fast." }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Review saved" }
        }
      }
    },
    "/api/payments/deposit": {
      "post": {
        "summary": "Deposit Wallet Funds",
        "tags": ["Payments"],
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/DepositInput" } }
          }
        },
        "responses": {
          "200": { "description": "Checkout link initialized" }
        }
      }
    },
    "/api/payments/webhook": {
      "post": {
        "summary": "Paystack Event Webhook Handler",
        "tags": ["Payments"],
        "description": "Receives callbacks from Paystack, verifies signatures, and updates balances.",
        "responses": {
          "200": { "description": "Processed" }
        }
      }
    },
    "/api/payments/escrow/lock": {
      "post": {
        "summary": "Lock Milestone Funds in Escrow",
        "tags": ["Payments"],
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["contractId", "milestoneId"],
                "properties": {
                  "contractId": { "type": "string" },
                  "milestoneId": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Locked" }
        }
      }
    },
    "/api/payments/withdraw": {
      "post": {
        "summary": "Initiate Wallet Withdrawal Transfer",
        "tags": ["Payments"],
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/WithdrawalInput" } }
          }
        },
        "responses": {
          "200": { "description": "Transfer queued" }
        }
      }
    },
    "/api/payments/history": {
      "get": {
        "summary": "Get Ledger Transactions History",
        "tags": ["Payments"],
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": { "description": "Ledger details" }
        }
      }
    },
    "/api/contracts/{contractId}/messages": {
      "get": {
        "summary": "Fetch Chat Thread Messages",
        "tags": ["Messages"],
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "contractId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 30 } }
        ],
        "responses": {
          "200": { "description": "Messages list" }
        }
      },
      "post": {
        "summary": "Send Text Chat Message",
        "tags": ["Messages"],
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "contractId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["content"],
                "properties": {
                  "content": { "type": "string", "example": "Hey, I started the task!" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Message dispatched" }
        }
      }
    },
    "/api/contracts/{contractId}/messages/file": {
      "post": {
        "summary": "Upload and Share Chat File",
        "tags": ["Messages"],
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "contractId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["file"],
                "properties": {
                  "file": { "type": "string", "format": "binary" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "File sent" }
        }
      }
    },
    "/api/contracts/{contractId}/messages/read": {
      "patch": {
        "summary": "Send Read Receipts",
        "tags": ["Messages"],
